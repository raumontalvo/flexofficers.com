generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OFFICER
  COMPANY
  ADMIN
}

enum ShiftStatus {
  OPEN
  FILLED
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officer       Officer?
  company       Company?
  notifications Notification[]
}

model Officer {
  id              String   @id @default(uuid())
  userId          String   @unique
  firstName       String
  lastName        String
  phone           String?
  city            String?
  state           String?
  experienceYears Int?
  bio             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenses     License[]
  applications Application[]
}

model License {
  id             String   @id @default(uuid())
  officerId      String
  licenseType    String
  licenseNumber  String
  expirationDate DateTime?
  issuingState   String
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
}

model Company {
  id            String   @id @default(uuid())
  userId        String   @unique
  companyName   String
  contactName   String?
  phone         String?
  website       String?
  city          String?
  state         String?
  description   String?
  licenseType   String?
  licenseNumber String?
  licenseState  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts Shift[]
}

model Shift {
  id              String      @id @default(uuid())
  companyId       String
  title           String
  description     String?
  location        String
  city            String?
  state           String?
  hourlyRate      Decimal
  startTime       DateTime
  endTime         DateTime
  requiredLicense String
  positionsNeeded Int         @default(1)
  status          ShiftStatus @default(OPEN)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id        String            @id @default(uuid())
  shiftId   String
  officerId String
  status    ApplicationStatus @default(PENDING)
  appliedAt DateTime          @default(now())

  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@unique([shiftId, officerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}