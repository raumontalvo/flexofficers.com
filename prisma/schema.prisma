generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OFFICER
  COMPANY
  ADMIN
}

enum ShiftStatus {
  OPEN
  INVITED
  PARTIALLY_FILLED
  FILLED
  COMPLETED
  CANCELLED
}

enum ShiftWorkType {
  GIG
  FULL_TIME
  PART_TIME
}

enum ShiftTimeType {
  DAY_SHIFT
  NIGHT_SHIFT
  OVERNIGHT
}

enum ShiftArmedRequirement {
  ARMED
  UNARMED
  EITHER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ArmedStatus {
  ARMED
  UNARMED
}

enum ShiftVisibility {
  PUBLIC
  STAFF_ONLY
}

enum CompanySubscriptionStatus {
  INACTIVE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum CompanyAccessStatus {
  TRIAL
  ACTIVE
  EXPIRED
}

enum LicenseVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                        String   @id @default(uuid())
  clerkId                   String   @unique
  email                     String   @unique
  role                      UserRole
  emailNotificationsEnabled Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  officer       Officer?
  company       Company?
  notifications Notification[]
  reviewedLicenses License[] @relation("LicenseReviewedBy")
}

model Officer {
  id                    String       @id @default(uuid())
  userId                String       @unique
  firstName             String
  lastName              String
  phone                 String?
  city                  String?
  state                 String?
  profilePhotoUrl       String?
  armedStatuses         ArmedStatus[] @default([])
  experienceYears       Int?
  availability          String[]     @default([])
  certifications        String[]     @default([])
  experienceCategories  String[]     @default([])
  introduction          String?
  bio                   String?
  licenseCertificationAccepted Boolean @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenses     License[]
  applications Application[]
  shiftInvites ShiftInvite[]
  companyStaff CompanyStaff[]
}

model License {
  id                  String                    @id @default(uuid())
  officerId           String
  licenseType         String
  licenseNumber       String
  expirationDate      DateTime
  issuingState        String
  verified            Boolean                   @default(false)
  verificationStatus  LicenseVerificationStatus @default(PENDING)
  verificationNotes   String?
  verifiedAt          DateTime?
  verifiedByUserId    String?
  documentKey         String?
  documentFileName    String?
  documentMimeType    String?
  documentSizeBytes   Int?
  documentUploadedAt  DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  officer    Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("LicenseReviewedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
}

model Company {
  id                         String                    @id @default(uuid())
  userId                     String                    @unique
  companyName                String
  contactName                String?
  phone                      String?
  email                      String?
  website                    String?
  address                    String?
  logoUrl                    String?
  city                       String?
  state                      String?
  description                String?
  licenseType                String?
  licenseNumber              String?
  licenseState               String?
  verified                   Boolean                   @default(false)
  subscriptionStatus         CompanySubscriptionStatus @default(INACTIVE)
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionPriceId        String?
  stripeCustomerId           String?                   @unique
  stripeSubscriptionId       String?                   @unique
  trialStartedAt             DateTime?
  trialEndsAt                DateTime?
  accessStatus               CompanyAccessStatus       @default(TRIAL)
  trialExtendedAt            DateTime?
  trialExtendedByAdminId     String?
  trialExtensionReason       String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts Shift[]
  staffMembers CompanyStaff[]
}

model Shift {
  id                    String                 @id @default(uuid())
  companyId             String
  title                 String
  description           String?
  location              String
  city                  String?
  state                 String?
  hourlyRate            Decimal
  startTime             DateTime
  endTime               DateTime
  workType              ShiftWorkType?
  shiftTimeType         ShiftTimeType?
  armedRequirement      ShiftArmedRequirement?
  requirements          String[]               @default([])
  otherRequirements     String?
  specialRequirements   String
  reportingInstructions String?
  positionsNeeded       Int                    @default(1)
  visibility            ShiftVisibility        @default(PUBLIC)
  status                ShiftStatus            @default(OPEN)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  shiftInvites ShiftInvite[]
}

model Application {
  id        String            @id @default(uuid())
  shiftId   String
  officerId String
  status    ApplicationStatus @default(PENDING)
  appliedAt DateTime          @default(now())

  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@unique([shiftId, officerId])
}

model ShiftInvite {
  id          String       @id @default(uuid())
  shiftId     String
  officerId   String
  status      InviteStatus @default(PENDING)
  message     String?
  invitedAt   DateTime     @default(now())
  respondedAt DateTime?

  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@unique([shiftId, officerId])
}

model CompanyStaff {
  id        String   @id @default(uuid())
  companyId String
  officerId String
  addedAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@unique([companyId, officerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}